{
  "id": null,
  "uid": "raceflow-overview",
  "title": "RaceFlow — Vista General",
  "description": "Estado de los 6 microservicios, métricas de negocio y SLO de latencia de ranking",
  "tags": [
    "raceflow",
    "overview"
  ],
  "timezone": "browser",
  "refresh": "15s",
